<% content_for :title, "Jobs" %>

<div class="container py-4 py-lg-5">
  <% if notice.present? %>
    <div class="alert alert-success mb-4" role="alert"><%= notice %></div>
  <% end %>

  <div class="mb-4">
    <%= link_to "Home", root_path, class: "btn btn-outline-secondary btn-sm" %>
  </div>

  <header class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3 mb-4 pb-2 border-bottom">
    <div>
      <h1 class="h2 mb-1 fw-semibold">Jobs</h1>
      <p class="text-body-secondary mb-0 small">Track every application from saved through offer.</p>
    </div>
    <%= link_to "New Job", new_job_path, class: "btn btn-primary" %>
  </header>

  <% if @jobs.any? %>
    <div id="jobs" class="vstack gap-3">
      <% @jobs.each do |job| %>
        <%= render job %>
      <% end %>
    </div>
  <% else %>
    <div class="card shadow-sm border-0">
      <div class="card-body p-4 p-lg-5 text-center">
        <h2 class="h5 fw-semibold mb-2">No jobs yet</h2>
        <p class="text-body-secondary mb-4">Add your first opening to start tracking applications and deadlines.</p>
        <%= link_to "Add a Job", new_job_path, class: "btn btn-primary" %>
      </div>
    </div>
  <% end %>
</div>
