<%= form_with(model: job) do |form| %>
  <div class="card shadow-sm border-0">
    <div class="card-body p-4 p-lg-5">
      <% if job.errors.any? %>
        <div class="alert alert-danger mb-4" role="alert">
          <p class="fw-semibold mb-2"><%= pluralize(job.errors.count, "error") %> prohibited this job from being saved:</p>
          <ul class="mb-0 ps-3">
            <% job.errors.each do |error| %>
              <li><%= error.full_message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="row g-3">
        <div class="col-12 col-md-7">
          <%= form.label :title, "Job title", class: "form-label" %>
          <%= form.text_field :title, class: "form-control", placeholder: "e.g. Software Engineer Intern" %>
        </div>

        <div class="col-12 col-md-5">
          <%= form.label :organization_name, "Organization", class: "form-label" %>
          <%= form.text_field :organization_name, class: "form-control", placeholder: "Company or program" %>
        </div>

        <div class="col-12 col-md-4">
          <%= form.label :status, class: "form-label" %>
          <%= form.select :status, job_status_options, { include_blank: "Select status" }, class: "form-select" %>
        </div>

        <div class="col-6 col-md-4">
          <%= form.label :deadline, class: "form-label" %>
          <%= form.date_field :deadline, class: "form-control" %>
        </div>

        <div class="col-6 col-md-4">
          <%= form.label :start_date, "Start date", class: "form-label" %>
          <%= form.date_field :start_date, class: "form-control" %>
        </div>

        <div class="col-12 col-md-8">
          <%= form.label :resume_id, "Resume", class: "form-label" %>
          <%= form.collection_select :resume_id,
                                     Resume.with_attached_file.order(created_at: :desc),
                                     :id,
                                     :display_name,
                                     { include_blank: "Select Resume" },
                                     class: "form-select" %>
        </div>

        <div class="col-12">
          <%= form.label :description, class: "form-label" %>
          <%= form.textarea :description, rows: 6, class: "form-control", placeholder: "Notes, links, requirements, contacts…" %>
        </div>
      </div>

      <div class="d-flex flex-column-reverse flex-sm-row justify-content-between align-items-stretch align-items-sm-center gap-2 mt-4 pt-3 border-top">
        <%= link_to "Back to Jobs", jobs_path, class: "btn btn-outline-secondary" %>
        <%= form.submit "Save Job", class: "btn btn-primary" %>
      </div>
    </div>
  </div>
<% end %>
