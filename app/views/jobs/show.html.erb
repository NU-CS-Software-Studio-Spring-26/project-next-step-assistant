<% content_for :title, @job.title.presence || "Job" %>

<div class="container py-4 py-lg-5">
  <div class="mb-4">
    <%= link_to "Back to Jobs", jobs_path, class: "btn btn-outline-secondary btn-sm" %>
  </div>

  <div class="card shadow-sm border-0">
    <div class="card-body p-4 p-lg-5">
      <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start gap-3 mb-4 pb-3 border-bottom">
        <div>
          <h1 class="h2 mb-1 fw-semibold"><%= @job.title.presence || "Untitled role" %></h1>
          <% if @job.organization_name.present? %>
            <p class="text-body-secondary mb-0"><%= @job.organization_name %></p>
          <% end %>
        </div>
        <% if @job.status.present? %>
          <span class="badge rounded-pill <%= job_status_badge_class(@job.status) %> fs-6"><%= job_status_label(@job.status) %></span>
        <% end %>
      </div>

      <dl class="row mb-0 gy-3">
        <dt class="col-sm-3 text-body-secondary small text-uppercase fw-semibold">Deadline</dt>
        <dd class="col-sm-9 mb-0">
          <% if @job.deadline.present? %>
            <%= @job.deadline.to_fs(:long) %>
          <% else %>
            <span class="text-body-secondary">—</span>
          <% end %>
        </dd>

        <dt class="col-sm-3 text-body-secondary small text-uppercase fw-semibold">Start date</dt>
        <dd class="col-sm-9 mb-0">
          <% if @job.start_date.present? %>
            <%= @job.start_date.to_fs(:long) %>
          <% else %>
            <span class="text-body-secondary">—</span>
          <% end %>
        </dd>

        <dt class="col-sm-3 text-body-secondary small text-uppercase fw-semibold">Description</dt>
        <dd class="col-sm-9 mb-0">
          <% if @job.description.present? %>
            <div class="text-body lh-base"><%= simple_format(@job.description) %></div>
          <% else %>
            <span class="text-body-secondary">—</span>
          <% end %>
        </dd>

        <dt class="col-sm-3 text-body-secondary small text-uppercase fw-semibold">Selected resume</dt>
        <dd class="col-sm-9 mb-0">
          <% if @job.resume&.file&.attached? %>
            <%= link_to "Download Resume", @job.resume.file, class: "btn btn-sm btn-outline-primary" %>
          <% else %>
            <span class="text-body-secondary">—</span>
          <% end %>
        </dd>
      </dl>

      <section class="mt-4 pt-4 border-top" aria-labelledby="job-resume-section-heading">
        <h2 id="job-resume-section-heading" class="h6 text-body-secondary text-uppercase fw-semibold mb-3">Resume</h2>
        <%= form_with model: @job, class: "card bg-body-tertiary border-0" do |form| %>
          <%= hidden_field_tag :from_show, "1" %>
          <div class="card-body p-3">
            <% if @job.errors.any? %>
              <div class="alert alert-danger mb-3" role="alert">
                <ul class="mb-0 small ps-3">
                  <% @job.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>
            <div class="row g-2 align-items-end">
              <div class="col-sm-8">
                <%= render "resume_select", form: form %>
              </div>
              <div class="col-sm-4">
                <%= form.submit "Update resume", class: "btn btn-primary w-100" %>
              </div>
            </div>
            <p class="small text-body-secondary mb-0 mt-2">
              Choose from your <%= link_to "resume library", resumes_path, class: "link-primary" %>.
              <%= link_to "Upload a new resume", new_resume_path, class: "link-primary" %> if needed.
            </p>
          </div>
        <% end %>
      </section>

      <div class="d-flex flex-column flex-sm-row flex-wrap gap-2 mt-4 pt-4 border-top">
        <%= link_to "Edit Job", edit_job_path(@job), class: "btn btn-primary" %>
        <%= link_to "Back to Jobs", jobs_path, class: "btn btn-outline-secondary" %>
        <%= button_to "Delete Job", @job, method: :delete, class: "btn btn-outline-danger", form: { class: "d-inline", data: { turbo_confirm: "Delete this job? This cannot be undone." } } %>
      </div>
    </div>
  </div>
</div>
