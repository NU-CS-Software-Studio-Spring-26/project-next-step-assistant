<div id="<%= dom_id job %>" class="card shadow-sm border-0">
  <div class="card-body p-4">
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start gap-2 mb-2">
      <div>
        <h2 class="card-title h5 mb-1 fw-semibold"><%= job.title.presence || "Untitled role" %></h2>
        <% if job.organization_name.present? %>
          <p class="text-body-secondary mb-0 small"><%= job.organization_name %></p>
        <% end %>
      </div>
      <% if job.status.present? %>
        <span class="badge rounded-pill <%= job_status_badge_class(job.status) %>"><%= job_status_label(job.status) %></span>
      <% end %>
    </div>

    <% if job.deadline.present? || job.start_date.present? %>
      <div class="d-flex flex-wrap gap-3 mb-3 small text-body-secondary">
        <% if job.deadline.present? %>
          <span><strong class="text-uppercase fw-semibold" style="font-size: 0.7rem; letter-spacing: 0.05em;">Deadline</strong> <%= job.deadline.to_fs(:long) %></span>
        <% end %>
        <% if job.start_date.present? %>
          <span><strong class="text-uppercase fw-semibold" style="font-size: 0.7rem; letter-spacing: 0.05em;">Starts</strong> <%= job.start_date.to_fs(:long) %></span>
        <% end %>
      </div>
    <% end %>

    <% if job.description.present? %>
      <p class="card-text text-body-secondary mb-3 lh-base"><%= truncate(job.description.to_s, length: 160, separator: " ") %></p>
    <% end %>

    <div class="d-flex flex-wrap gap-2 pt-3 border-top">
      <%= link_to "Show", job, class: "btn btn-primary btn-sm" %>
      <%= link_to "Edit", edit_job_path(job), class: "btn btn-outline-secondary btn-sm" %>
      <%= button_to "Delete", job, method: :delete, class: "btn btn-outline-danger btn-sm", form: { class: "d-inline", data: { turbo_confirm: "Delete this job? This cannot be undone." } } %>
    </div>
  </div>
</div>
