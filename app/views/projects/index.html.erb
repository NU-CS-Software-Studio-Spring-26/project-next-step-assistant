<% content_for :title, "Projects" %>

<div class="container py-4 py-lg-5">
  <% if notice.present? %>
    <div class="alert alert-success mb-4" role="alert"><%= notice %></div>
  <% end %>

  <div class="mb-4">
    <%= link_to "Home", root_path, class: "btn btn-outline-secondary btn-sm" %>
  </div>

  <header class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3 mb-4 pb-2 border-bottom">
    <h1 class="h2 mb-0 fw-semibold">Projects</h1>
    <%= link_to "New Project", new_project_path, class: "btn btn-primary" %>
  </header>

  <div id="projects" class="vstack gap-3">
    <% @projects.each do |project| %>
      <%= render project %>
    <% end %>
  </div>
</div>
