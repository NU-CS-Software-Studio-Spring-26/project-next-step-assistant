<%= form_with(model: project) do |form| %>
  <div class="card shadow-sm border-0">
    <div class="card-body p-4 p-lg-5">
      <% if project.errors.any? %>
        <div class="alert alert-danger mb-4" role="alert">
          <p class="fw-semibold mb-2"><%= pluralize(project.errors.count, "error") %> prohibited this project from being saved:</p>
          <ul class="mb-0 ps-3">
            <% project.errors.each do |error| %>
              <li><%= error.full_message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="mb-3">
        <%= form.label :name, class: "form-label" %>
        <%= form.text_field :name, class: "form-control", maxlength: Project::NAME_MAX_LENGTH %>
      </div>

      <div class="mb-3">
        <%= form.label :github_link, class: "form-label" %>
        <%= form.text_field :github_link, class: "form-control", maxlength: Project::GITHUB_LINK_MAX_LENGTH %>
      </div>

      <div class="mb-3">
        <%= form.label :skills, class: "form-label" %>
        <%= form.text_field :skills, class: "form-control", maxlength: Project::SKILLS_MAX_LENGTH %>
      </div>

      <div class="mb-4">
        <%= form.label :description, class: "form-label" %>
        <%= form.textarea :description, rows: 8, class: "form-control", maxlength: Project::DESCRIPTION_MAX_LENGTH %>
      </div>

      <div class="d-flex flex-column-reverse flex-sm-row justify-content-between align-items-stretch align-items-sm-center gap-2 pt-3 border-top">
        <%= link_to "Back to Projects", projects_path, class: "btn btn-outline-secondary" %>
        <%= form.submit "Save Project", class: "btn btn-primary" %>
      </div>
    </div>
  </div>
<% end %>
