<% content_for :title, "Resume Library" %>

<div class="container py-4 py-lg-5">
  <header class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3 mb-4 pb-2 border-bottom">
    <div>
      <h1 class="h2 mb-1 fw-semibold">Resume Library</h1>
      <p class="text-body-secondary mb-0 small">Upload once, reuse across multiple jobs.</p>
    </div>
    <%= link_to "Upload Resume", new_resume_path, class: "btn btn-primary" %>
  </header>

  <% if @resumes.any? %>
    <ul class="list-group shadow-sm">
      <% @resumes.each do |resume| %>
        <li class="list-group-item d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3">
          <div>
            <% if resume.file.attached? %>
              <h2 class="h6 fw-semibold mb-0"><%= link_to resume.name, resume_path(resume), class: "text-decoration-none" %></h2>
              <div class="small text-body-secondary"><%= resume.file.filename %></div>
              <div class="small text-body-secondary">Uploaded <%= l(resume.created_at.to_date, format: :long) %></div>
              <div class="small text-body-secondary">Used by <%= pluralize(resume.jobs.count, "job") %></div>
            <% else %>
              <h2 class="h6 fw-semibold mb-0 text-body-secondary"><%= link_to resume.name, resume_path(resume), class: "text-decoration-none link-secondary" %></h2>
              <div class="small text-body-secondary">Missing file</div>
              <div class="small text-body-secondary">Uploaded <%= l(resume.created_at.to_date, format: :long) %></div>
              <div class="small text-body-secondary">Used by <%= pluralize(resume.jobs.count, "job") %></div>
            <% end %>
          </div>
          <div class="d-flex gap-2">
            <% if resume.file.attached? %>
              <%= link_to "Download", resume.file, class: "btn btn-sm btn-outline-primary" %>
            <% end %>
            <%= button_to "Delete", resume_path(resume), method: :delete, class: "btn btn-sm btn-outline-danger", form: { data: { turbo_confirm: "Delete this resume?" } } %>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="card shadow-sm border-0">
      <div class="card-body p-4 p-lg-5 text-center">
        <h2 class="h5 fw-semibold mb-2">No resumes uploaded yet</h2>
        <p class="text-body-secondary mb-4">Upload a PDF resume to start using the reusable library.</p>
        <%= link_to "Upload Resume", new_resume_path, class: "btn btn-primary" %>
      </div>
    </div>
  <% end %>
</div>
