<% content_for :title, "Upload Resume" %>

<div class="container py-4 py-lg-5">
  <div class="mb-4">
    <%= link_to "Back to Resume Library", resumes_path, class: "btn btn-outline-secondary btn-sm" %>
  </div>

  <div class="card shadow-sm border-0" style="max-width: 36rem;">
    <div class="card-body p-4">
      <h1 class="h4 fw-semibold mb-3">Upload resume</h1>
      <p class="text-body-secondary small mb-4">Add a PDF resume to your reusable library.</p>
      <%= render "form", resume: @resume, job: @job %>
    </div>
  </div>
</div>
