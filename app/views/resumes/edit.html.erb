<% content_for :title, "Edit Resume" %>

<div class="container py-4 py-lg-5">
  <div class="mb-4">
    <%= link_to "Back to Resume", resume_path(@resume), class: "btn btn-outline-secondary btn-sm" %>
  </div>

  <div class="card shadow-sm border-0" style="max-width: 36rem;">
    <div class="card-body p-4">
      <h1 class="h4 fw-semibold mb-3">Edit resume</h1>
      <p class="text-body-secondary small mb-4">Update the resume name and optionally replace the file.</p>
      <%= render "form", resume: @resume, job: nil %>
    </div>
  </div>
</div>
