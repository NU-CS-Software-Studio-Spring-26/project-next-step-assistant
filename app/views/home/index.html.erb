<main class="home-page">
	<section class="hero">
		<p class="eyebrow">Next Step Assistant</p>
		<h1>Track every application, interview, and follow-up in one place.</h1>
		<p class="hero-copy">
			Keep your search organized with a simple workflow for jobs and projects, so you can spend more time applying and less time hunting through notes.
		</p>

		<div class="hero-actions">
			<%= link_to "View Jobs", jobs_path, class: "btn-primary-home" %>
			<%= link_to "Browse Projects", projects_path, class: "btn-secondary-home" %>
		</div>
	</section>

	<section class="deadline-tracker mt-4 mb-4" aria-label="Upcoming job deadlines">
		<div class="card border-0 shadow-sm overflow-hidden">
			<div class="card-header bg-white border-bottom py-3 px-3 px-md-4">
				<h2 class="h5 mb-0 fw-semibold">Deadline tracker</h2>
				<p class="text-body-secondary small mb-0 mt-1">Applications sorted by due date.</p>
			</div>
			<% if @deadline_jobs.any? %>
				<ul class="list-group list-group-flush">
					<% today = Date.current %>
					<% @deadline_jobs.each do |job| %>
						<% days_remaining = (job.deadline - today).to_i %>
						<% urgency_class, urgency_style =
							if days_remaining <= 1
								["list-group-item-danger", nil]
							elsif days_remaining <= 3
								["list-group-item", "background-color: rgba(253, 126, 20, 0.22);"]
							elsif days_remaining <= 7
								["list-group-item-warning", nil]
							else
								["list-group-item-success", nil]
							end %>
						<li class="list-group-item <%= urgency_class %> px-3 px-md-4 py-3"<% if urgency_style %> style="<%= urgency_style %>"<% end %>>
							<div class="d-flex flex-column flex-sm-row flex-sm-wrap justify-content-between align-items-start gap-2">
								<div>
									<div class="fw-semibold"><%= job.title %></div>
									<div class="small text-body-secondary"><%= job.organization_name.presence || "—" %></div>
									<div class="small mt-1"><span class="text-body-secondary">Deadline:</span> <%= l(job.deadline, format: :long) %></div>
								</div>
								<div class="text-sm-end">
									<% if days_remaining.negative? %>
										<span class="badge rounded-pill text-bg-danger">Overdue <%= pluralize(days_remaining.abs, "day") %></span>
									<% elsif days_remaining.zero? %>
										<span class="badge rounded-pill text-bg-danger">Due today</span>
									<% else %>
										<span class="badge rounded-pill <%= days_remaining <= 1 ? "text-bg-danger" : (days_remaining <= 3 ? "text-bg-warning text-dark" : (days_remaining <= 7 ? "text-bg-warning text-dark" : "text-bg-success")) %>">
											<%= pluralize(days_remaining, "day") %> left
										</span>
									<% end %>
								</div>
							</div>
						</li>
					<% end %>
				</ul>
			<% else %>
				<div class="card-body text-body-secondary small">
					No jobs with deadlines yet. <%= link_to "Add deadlines on the Jobs page", jobs_path, class: "link-primary" %>.
				</div>
			<% end %>
		</div>
	</section>

	<section class="home-grid" aria-label="Homepage highlights">
		<article class="home-card">
			<h2>Jobs Board</h2>
			<p>Add openings, update statuses, and keep momentum with one focused list.</p>
			<%= link_to "Go to Jobs", jobs_path, class: "card-link" %>
		</article>

		<article class="home-card accent">
			<h2>Projects Hub</h2>
			<p>Capture project work tied to your applications and present your strengths clearly.</p>
			<%= link_to "Go to Projects", projects_path, class: "card-link" %>
		</article>

		<article class="home-card wide">
			<h2>Simple, consistent workflow</h2>
			<ul>
				<li>Track applications and deadlines.</li>
				<li>Organize portfolio projects by relevance.</li>
				<li>Review progress quickly before interviews.</li>
			</ul>
		</article>
	</section>
</main>