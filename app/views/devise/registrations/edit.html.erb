<div class="auth-wrap">
  <div class="auth-card">
    <p class="eyebrow">Next Step Assistant</p>
    <h1 class="auth-heading">Edit your account</h1>
    <p class="auth-sub">Update your email or password. Leave password fields blank to keep your current password.</p>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
      <% if resource.errors.any? %>
        <div class="auth-errors">
          <strong><%= pluralize(resource.errors.count, "error") %> prevented your account from being saved:</strong>
          <ul>
            <% resource.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="auth-field">
        <%= f.label :email, class: "auth-label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "auth-input", maxlength: User::EMAIL_MAX_LENGTH %>
      </div>

      <div class="auth-field">
        <%= f.label :password, "New password", class: "auth-label" %>
        <%= f.password_field :password, autocomplete: "new-password", class: "auth-input", maxlength: User::PASSWORD_MAX_LENGTH %>
        <%= render "devise/shared/password_requirements" %>
      </div>

      <div class="auth-field">
        <%= f.label :password_confirmation, "Confirm new password", class: "auth-label" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "auth-input", maxlength: User::PASSWORD_MAX_LENGTH %>
      </div>

      <div class="auth-field">
        <%= f.label :current_password, class: "auth-label" %>
        <%= f.password_field :current_password, autocomplete: "current-password", class: "auth-input", maxlength: User::PASSWORD_MAX_LENGTH %>
        <p class="auth-hint">Required to confirm changes to your account.</p>
      </div>

      <%= f.submit "Update account", class: "auth-btn" %>
    <% end %>

    <div class="auth-links">
      <%= link_to "Back", :back %>
    </div>
  </div>
</div>
