<div class="auth-wrap">
  <div class="auth-card">
    <p class="eyebrow">Next Step Assistant</p>
    <h1 class="auth-heading">Create your account</h1>
    <p class="auth-sub">Track applications, deadlines, and projects in one place.</p>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <% if resource.errors.any? %>
        <div class="auth-errors">
          <strong><%= pluralize(resource.errors.count, "error") %> prevented your account from being saved:</strong>
          <ul>
            <% resource.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="auth-field">
        <%= f.label :email, class: "auth-label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "auth-input" %>
      </div>

      <div class="auth-field">
        <%= f.label :password, class: "auth-label" %>
        <%= f.password_field :password, autocomplete: "new-password", class: "auth-input" %>
        <% if @minimum_password_length %>
          <p class="auth-hint"><%= @minimum_password_length %> characters minimum</p>
        <% end %>
      </div>

      <div class="auth-field">
        <%= f.label :password_confirmation, "Confirm password", class: "auth-label" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "auth-input" %>
      </div>

      <%= f.submit "Sign up", class: "auth-btn" %>
    <% end %>

    <div class="auth-links">
      Already have an account?
      <%= link_to "Log in", new_session_path(resource_name) %>
    </div>
  </div>
</div>
