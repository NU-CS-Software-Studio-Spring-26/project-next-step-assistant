<div class="auth-wrap">
  <div class="auth-card">
    <p class="eyebrow">Next Step Assistant</p>
    <h1 class="auth-heading">Welcome back</h1>
    <p class="auth-sub">Sign in to your account to continue.</p>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="auth-field">
        <%= f.label :email, class: "auth-label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "auth-input", maxlength: User::EMAIL_MAX_LENGTH %>
      </div>

      <div class="auth-field">
        <%= f.label :password, class: "auth-label" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "auth-input", maxlength: User::PASSWORD_MAX_LENGTH %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="auth-remember">
          <%= f.check_box :remember_me %>
          <%= f.label :remember_me %>
        </div>
      <% end %>

      <%= f.submit "Log in", class: "auth-btn" %>
    <% end %>

    <div class="auth-links">
      <%= link_to "Forgot your password?", new_password_path(resource_name) %>
      <span class="auth-divider">·</span>
      <%= link_to "Sign up", new_registration_path(resource_name) %>
    </div>
  </div>
</div>
